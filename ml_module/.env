# ML Service Configuration
ML_HOST=0.0.0.0
ML_PORT=8002
ML_DEBUG=false

# Neo4j Configuration
ML_NEO4J_URI=bolt://localhost:7687
ML_NEO4J_USER=neo4j
ML_NEO4J_PASSWORD=password

# Embedding Model
ML_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ML_EMBEDDING_DIM=384

# File Watching
ML_WATCH_INTERVAL=1.0
ML_BATCH_TIMEOUT=1.0
ML_MAX_FILE_SIZE=10485760

# TypeScript Service (optional)
# ML_TYPESCRIPT_SERVICE_URL=http://localhost:3000