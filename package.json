{
  "name": "mcp-pif",
  "version": "3.0.0",
  "description": "Personal Intelligence Framework - MCP Server",
  "main": "dist/index.js",
  "bin": {
    "pif": "dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "ts-node test/integration.test.ts",
    "start:all": "./start-all.sh",
    "start:dev": "node start-dev.js",
    "start:interactive": "./start-interactive.sh",
    "ml:setup": "cd src/ml_module && ./setup.sh",
    "ml:start": "cd src/ml_module && ./run.sh"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^9.0.0",
    "glob": "^10.3.10",
    "mime-types": "^2.1.35",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.14",
    "@types/mime-types": "^2.1.1",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "mcp",
    "ai",
    "knowledge-management"
  ],
  "author": "",
  "license": "MIT"
}
